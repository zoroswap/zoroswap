end


#! Returns POOL CURVE
#!
#! Inputs: [0, 0, 0, 0]
#! Outputs: [c, beta, 0, 0]
#!
pub proc get_pool_curve
    push.0.0.0
    push.POOL_CURVE_MAPPING_SLOT[0..2]
    exec.active_account::get_map_item
    swap.2 drop
    swap.2 drop
end



# WALLET FUNCTIONS

#! Adds the provided asset to the active account.
#!
#! Inputs:  [ASSET, reserve, reserve_with_slippage, liabilities, 0, pad(8)]
#! Outputs: [pad(16)]
#!
#! Where:
#! - ASSET is the asset to be received, can be fungible or non-fungible
#!
#! Panics if:
#! - the same non-fungible asset already exists in the account.
#! - adding a fungible asset would result in amount overflow, i.e.,
#!   the total amount would be greater than 2^63.
#!
#! Invocation: call
@locals(4)
pub proc receive_asset
    push.10000 debug.stack.9 drop
    loc_storew_be.0 exec.expand_asset
    push.10001 debug.stack.9 drop
    # => [ASSET_KEY, ASSET_VALUE,  reserve_with_slippage, liabilities, 0, pad(8)]
    exec.native_account::add_asset
    push.10002 debug.stack.5 drop
    # => [ASSET_VALUE', reserve, reserve_with_slippage, liabilities, 0, pad(8)]
    loc_loadw_be.0
    # => [ASSET, reserve, reserve_with_slippage, liabilities, 0, pad(8)]
    procref.validate_and_update_state reversew mem_storew_be.DYNAMIC_PROC_ADDR dropw push.DYNAMIC_PROC_ADDR
    push.10003 debug.stack.1 drop
    dynexec
    # => [pad(16)]
end

#proc validate_and_update_state
#   push.0 drop
#end

proc validate_and_update_state
   exec.set_pool_state
end

#! Adds the provided asset to the an output note.
#!
#! Inputs:  [ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0, pad(4)]
#! Outputs: [pad(16)]
#!
#! Where:
#! - ASSET is the asset to be received, can be fungible or non-fungible
#!
#! Panics if:
#! - the same non-fungible asset already exists in the account.
#! - adding a fungible asset would result in amount overflow, i.e.,
#!   the total amount would be greater than 2^63.
#!
@locals(4)
pub proc move_asset_to_note
    ## loc.0: ASSET_OUT
    loc_storew_be.0 
    exec.expand_asset
    # => [ASSET_OUT_KEY, ASSET_OUT_VALUE, note_idx, 0,0,0, liabilities, reserve, reserve_with_slippage, 0, pad(4)]
    exec.native_account::remove_asset
    # => [ASSET_OUT_VALUE, note_idx, 0,0,0, liabilities, reserve, reserve_with_slippage, 0, pad(4)]
    loc_loadw_be.0 exec.expand_asset
    # => [ASSET_OUT_KEY, ASSET_OUT_VALUE, note_idx, 0,0,0, liabilities, reserve, reserve_with_slippage, 0, pad(4)]
   
    exec.output_note::add_asset
    # => [0,0,0, liabilities, reserve, reserve_with_slippage, 0, pad(4)]

    #swapw.1 dropw
    ### todo: padw later after note_idx is passed as felt not a word
    push.0 loc_loadw_be.0
    # => [ ASSET_OUT, liabilities, reserve, reserve_with_slippage, 0]
    exec.set_pool_state
end

#! Move asset from current note and immediately add it to another.
#!
#! Inputs:  [ASSET, noteid]
#! Outputs: [pad(16)]
#!
#! Where:
#! - ASSET is the asset to be bounced, can be fungible or non-fungible
#!
#! Panics if:
#! - the same non-fungible asset already exists in the account.
#! - adding a fungible asset would result in amount overflow, i.e.,
#!   the total amount would be greater than 2^63.
#!
pub proc bounce_asset
    mem_storew_be.BOUNCE_ASSET_LOC
    exec.native_account::add_asset
    dropw
    mem_loadw_be.BOUNCE_ASSET_LOC
    exec.native_account::remove_asset

    exec.output_note::add_asset
end


#! add new deposit: receive asset, update deposit mapping
#!
#! Inputs: [ASSET, POOL_STATE,user_id_suffix, user_id_prefix, lp_amount_out]
#! Outputs: [share_amount]
#!
pub proc deposit
    push.101 debug.stack.5 drop
    mem_storew_le.DEPOSIT_ASSET_LOC
    exec.receive_asset
    push.102 debug.stack.1 drop
    padw mem_loadw_le.DEPOSIT_ASSET_LOC
    # => [ASSET, beneficiary_suffix, beneficiary_prefix, lp_amount_out]
    exec.get_user_deposit_key
    # => [KEY, lp_amount_out]
    mem_storew_be.DEPOSIT_KEY_LOC
    movup.4
    # => [lp_amount_out, KEY]
    dup mem_store.LP_SHARES_AMOUNT_ADDR
    movdn.4 #swapw
    # => [KEY, share_amount]
    push.USER_DEPOSITS_MAPPING_SLOT[0..2]
    # => [slot_id_prefix, slot_id_suffix, KEY, share_amount]
    exec.storage_utils::add_to_map_item
    # => [new_value]
    drop
    # update total supply
    mem_load.LP_SHARES_AMOUNT_ADDR 
    padw mem_loadw_be.DEPOSIT_KEY_LOC
    # => [KEY, share_amount]
    exec.get_lp_shares_total_supply_key
    # => [TOTAL_SUPPLY_KEY, share_amount]
    push.USER_DEPOSITS_MAPPING_SLOT[0..2]
    # => [slot_id_prefix, slot_id_suffix, KEY, share_amount]
    exec.storage_utils::add_to_map_item
    # => []
end

#! Inputs:  [user_id_suffix, user_id_prefix, lp_withdraw_amount, 0, ASSET_OUT, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage]
@locals(1)
pub proc withdraw
    # loc.0: old_user_lp_shares
    dupw
    # => [user_id_suffix, user_id_prefix, lp_withdraw_amount, 0, user_id_suffix, user_id_prefix, lp_withdraw_amount, 0, ASSET_OUT, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    dupw.2
    # => [ASSET_OUT, user_id_suffix, user_id_prefix, lp_withdraw_amount, 0, user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET_OUT, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    exec.get_user_deposit_key
    # => [KEY, lp_withdraw_amount, 0,  user_id_suffix, user_id_prefix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0 ]
    mem_storew_be.WITHDRAW_KEY_LOC
    exec.get_user_deposit loc_store.0 loc_load.0
    # => [old_user_lp_shares, lp_withdraw_amount, 0, user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    swap sub
    # => [new_user_lp_shares, 0, user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0 ]
    dup
    # => [new_user_lp_shares, new_user_lp_shares, 0, user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    loc_load.0
    # => [old_user_lp_shares, new_user_lp_shares, new_user_lp_shares, 0, user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    lt assert.err=ERR_LP_WITHDRAW_AMOUNT_EXCEEDS_USER_LP_SHARES
    # => [new_user_lp_shares, 0, user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    # => [NEW_USER_LP_SHARES, 0, user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    padw mem_loadw_be.WITHDRAW_KEY_LOC
    push.USER_DEPOSITS_MAPPING_SLOT[0..2]
    # => [slot_id_prefix, slot_id_suffix, KEY, NEW_USER_LP_SHARES]
    exec.storage_utils::set_map_item #exec.native_account::set_map_item
    drop drop #dropw drop
    # => [user_id_prefix, user_id_suffix, lp_withdraw_amount, 0, ASSET, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    drop drop swap drop
    # => [lp_withdraw_amount]

    padw mem_loadw_be.WITHDRAW_KEY_LOC
    exec.get_lp_shares_total_supply_key
    # => [KEY, lp_withdraw_amount]
    push.USER_DEPOSITS_MAPPING_SLOT[0..2]
    # => [slot_id_prefix, slot_id_suffix, KEY, SHARE_AMOUNT]
    exec.storage_utils::sub_from_map_item drop# exec.sub_from_map_item
    # => [ ASSET_OUT, noteid, 0,0,0, liabilities, reserve, reserve_with_slippage, 0]
    exec.move_asset_to_note
    dropw dropw dropw
end


#! Returns user LP shares amount
#!
#! Inputs: [KEY]
#! Outputs: [share_amount]
#!
proc get_user_deposit
    # => [KEY]
    push.USER_DEPOSITS_MAPPING_SLOT[0..2]
    exec.active_account::get_map_item
    swap.3 drop drop drop
    # => [share_amount]
end


#! Returns user LP shares mapping  key
#!
#! Inputs: [ASSET, user_id_suffix, user_id_prefix]
#! Outputs: [KEY]
#!
proc get_user_deposit_key
    exec.address_from_asset
    # => [asset_account_prefix, asset_account_suffix, user_id_suffix, user_id_prefix]
    # => [KEY]
end

#! Returns user LP shares mapping  key
#!
#! Inputs: [ASSET]
#! Outputs: [KEY]
#!
proc get_lp_shares_total_supply_key
    exec.address_word_from_asset
end

