#! UTILS
#! Returns ASSET ADDRESS followd by two 0 felts
#!
#! Inputs: [ASSET]
#! Outputs: [asset_account_suffix, asset_account_prefix, 0, 0]
#!
proc address_word_from_asset
    push.0 swap.3 drop
    push.0 swap.4 drop
end

#! Returns ASSET ADDRESS
#!
#! Inputs: [ASSET]
#! Outputs: [asset_account_suffix, asset_accout_prefix]
#!
proc address_from_asset
    swap.2 drop
    swap.2 drop
end

