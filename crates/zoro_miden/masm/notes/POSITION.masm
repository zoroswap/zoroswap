# @todo consider moving to pointer to a standarised location - read it from common library
const SELL_ASSET_POINTER = FREE_MEMORY_POINTER
const SELL_ASSET_AMOUNT_POINTER = SELL_ASSET_POINTER + 3
const BUY_ASSET_POINTER = SELL_ASSET_POINTER + 4
const BUY_ASSET_AMOUNT_POINTER = BUY_ASSET_POINTER + 3
const BUY_ASSET_END = BUY_ASSET_POINTER + 3




# META
